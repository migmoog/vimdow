[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/vimdow/bin/debug/libvimdow.so"
linux.release.x86_64 =   "res://addons/vimdow/bin/release/libvimdow.so"

windows.debug.x86_64 =   "res://addons/vimdow/bin/debug/vimdow.dll"
windows.release.x86_64 =  "res://addons/vimdow/bin/release/vimdow.dll"

macos.debug =             "res://addons/vimdow/bin/debug/libvimdow.dylib"
macos.release =           "res://addons/vimdow/bin/release/libvimdow.dylib"
macos.debug.arm64 =       "res://addons/vimdow/bin/debug/libvimdow.dylib"
macos.release.arm64 =     "res://addons/vimdow/bin/release/libvimdow.dylib"
